<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.SettingsPage"
    Title=""
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone='16,20', Default='28,24'}"
                         Spacing="20">

            <!-- ===== HEADER ===== -->
            <VerticalStackLayout Spacing="4"
                             Margin="0,0,0,4">

                <Label Text="Настройки"
                   FontSize="{OnIdiom Phone=24, Default=28}"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}" />

                <Label Text="Управляйте своим профилем и параметрами приложения"
                   FontSize="{OnIdiom Phone=12, Default=13}"
                   TextColor="{DynamicResource TextSecondary}" />

            </VerticalStackLayout>

            <!-- ===== PROFILE CARD ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}"
                Stroke="{DynamicResource CardStroke}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="{OnIdiom Phone='14,14', Default='20,18'}">

                <HorizontalStackLayout Spacing="{OnIdiom Phone=12, Default=18}"
                                   VerticalOptions="Center">

                    <!-- Аватар -->
                    <Border WidthRequest="{OnIdiom Phone=56, Default=72}"
                        HeightRequest="{OnIdiom Phone=56, Default=72}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#1E293B">

                        <Image x:Name="ProfileAvatar"
                           Aspect="AspectFill"/>

                    </Border>

                    <!-- Информация -->
                    <VerticalStackLayout Spacing="4"
                                     VerticalOptions="Center"
                                     HorizontalOptions="FillAndExpand">

                        <Label x:Name="ProfileName"
                           FontSize="{OnIdiom Phone=16, Default=20}"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           TextColor="{DynamicResource TextPrimary}" />

                        <VerticalStackLayout Spacing="2">

                            <HorizontalStackLayout Spacing="8">

                                <Border x:Name="StatusIndicator"
                                    WidthRequest="10"
                                    HeightRequest="10"
                                    StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5"/>
                                    </Border.StrokeShape>

                                </Border>

                                <Label x:Name="StatusText"
                                   FontSize="{OnIdiom Phone=12, Default=13}"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{DynamicResource TextSecondary}" />

                            </HorizontalStackLayout>

                            <Label x:Name="CurrentGameText"
                               FontSize="{OnIdiom Phone=11, Default=12}"
                               LineBreakMode="TailTruncation"
                               TextColor="{DynamicResource TextSecondary}"
                               IsVisible="False" />

                            <Label x:Name="ProfileSteamId"
                               FontSize="{OnIdiom Phone=11, Default=13}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               TextColor="{DynamicResource TextSecondary}" />

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Кнопка Steam -->
                    <Border x:Name="SteamProfileButton"
                        WidthRequest="{OnIdiom Phone=30, Default=36}"
                        HeightRequest="{OnIdiom Phone=30, Default=36}"
                        BackgroundColor="{DynamicResource CardBackground}"
                        Stroke="{DynamicResource CardStroke}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        VerticalOptions="Center">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OpenSteamProfileTapped"/>
                        </Border.GestureRecognizers>

                        <Label Text="↗"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{DynamicResource TextPrimary}"/>

                    </Border>

                </HorizontalStackLayout>

            </Border>

            <!-- ===== APPEARANCE CARD ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}"
                Stroke="{DynamicResource CardStroke}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="{OnIdiom Phone='14,14', Default='20,18'}">

                <VerticalStackLayout Spacing="18">

                    <Label Text="Оформление"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />

                    <FlexLayout Direction="Row"
                            Wrap="Wrap"
                            AlignItems="Center"
                            JustifyContent="Start">

                        <VerticalStackLayout Spacing="4"
                                         VerticalOptions="Center"
                                         FlexLayout.Basis="{OnIdiom Phone='100%', Default='Auto'}">

                            <Label Text="Тема приложения"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}" />

                            <Label Text="Выберите тему оформления приложения"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}" />

                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="{OnIdiom Phone=8, Default=14}"
                                           VerticalOptions="Center"
                                           FlexLayout.Basis="{OnIdiom Phone='100%', Default='Auto'}"
                                           Margin="{OnIdiom Phone='0,12,0,0', Default='40,0,0,0'}">

                            <!-- Тёмная -->
                            <VerticalStackLayout Spacing="6"
                                             HorizontalOptions="Center">

                                <Border x:Name="DarkBorder"
                                    WidthRequest="{OnIdiom Phone=88, Default=110}"
                                    HeightRequest="{OnIdiom Phone=74, Default=90}"
                                    BackgroundColor="#1A1A2E"
                                    Stroke="#4F6FFF"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 14">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDarkThemeTapped"/>
                                    </Border.GestureRecognizers>

                                    <Grid>

                                        <Image Source="sundark.png"
                                           WidthRequest="{OnIdiom Phone=34, Default=40}"
                                           HeightRequest="{OnIdiom Phone=34, Default=40}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                        <Border x:Name="DarkCheckmark"
                                            WidthRequest="22"
                                            HeightRequest="22"
                                            BackgroundColor="#4F6FFF"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="0,6,6,0">

                                            <Label Text="✓"
                                               FontSize="12"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>

                                        </Border>

                                    </Grid>

                                </Border>

                                <Label x:Name="DarkLabel"
                                   Text="Тёмная"
                                   FontSize="{OnIdiom Phone=11, Default=13}"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>

                            </VerticalStackLayout>

                            <!-- Полуночная -->
                            <VerticalStackLayout Spacing="6"
                                             HorizontalOptions="Center">

                                <Border x:Name="MidnightBorder"
                                    WidthRequest="{OnIdiom Phone=88, Default=110}"
                                    HeightRequest="{OnIdiom Phone=74, Default=90}"
                                    BackgroundColor="#0D0B1E"
                                    Stroke="#2E2660"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMidnightThemeTapped"/>
                                    </Border.GestureRecognizers>

                                    <Grid>

                                        <Image Source="midnight.png"
                                           WidthRequest="{OnIdiom Phone=34, Default=40}"
                                           HeightRequest="{OnIdiom Phone=34, Default=40}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                        <Border x:Name="MidnightCheckmark"
                                            WidthRequest="22"
                                            HeightRequest="22"
                                            BackgroundColor="#6C5CE7"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="0,6,6,0"
                                            IsVisible="False">

                                            <Label Text="✓"
                                               FontSize="12"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>

                                        </Border>

                                    </Grid>

                                </Border>

                                <Label x:Name="MidnightLabel"
                                   Text="Полуночная"
                                   FontSize="{OnIdiom Phone=11, Default=13}"
                                   TextColor="#9B8FCC"
                                   HorizontalOptions="Center"/>

                            </VerticalStackLayout>

                        </HorizontalStackLayout>

                    </FlexLayout>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
