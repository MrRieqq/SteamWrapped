<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.SettingsPage"
    Title=""
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="28,24" Spacing="20">

            <!-- ===== HEADER ===== -->
            <VerticalStackLayout Spacing="4" Margin="0,0,0,4">
                <Label
                    Text="Настройки"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{DynamicResource TextPrimary}"/>
                <Label
                    Text="Управляйте своим профилем и параметрами приложения"
                    FontSize="13"
                    TextColor="{DynamicResource TextSecondary}"/>
            </VerticalStackLayout>

            <!-- ===== PROFILE CARD ===== -->
            <Border
                BackgroundColor="{DynamicResource CardBackground}"
                Stroke="{DynamicResource CardStroke}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="20,18">
                <HorizontalStackLayout Spacing="18" VerticalOptions="Center">

                    <!-- Аватар -->
                    <Border WidthRequest="72"
            HeightRequest="72"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 14"
            BackgroundColor="#1E293B">

                        <Image x:Name="ProfileAvatar"
               Aspect="AspectFill"/>

                    </Border>

                    <!-- Информация -->
                    <VerticalStackLayout Spacing="6"
                         VerticalOptions="Center"
                         HorizontalOptions="FillAndExpand">

                        <Label x:Name="ProfileName"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="{DynamicResource TextPrimary}"/>

                        <VerticalStackLayout Spacing="2">

                            <HorizontalStackLayout Spacing="8">

                                <Border x:Name="StatusIndicator"
                        WidthRequest="10"
                        HeightRequest="10"
                        StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5"/>
                                    </Border.StrokeShape>

                                </Border>

                                <Label x:Name="StatusText"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondary}"/>

                            </HorizontalStackLayout>

                            <Label x:Name="CurrentGameText"
                   FontSize="12"
                   TextColor="{DynamicResource TextSecondary}"
                   IsVisible="False"/>

                            <Label x:Name="ProfileSteamId"
                   FontSize="13"
                   TextColor="{DynamicResource TextSecondary}"/>

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Кнопка Steam -->
                    <Border x:Name="SteamProfileButton"
        WidthRequest="36"
        HeightRequest="36"
        BackgroundColor="{DynamicResource CardBackground}"
        Stroke="{DynamicResource CardStroke}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 8"
        VerticalOptions="Center">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OpenSteamProfileTapped"/>
                        </Border.GestureRecognizers>

                        <Label Text="↗"
           FontSize="18"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           TextColor="{DynamicResource TextPrimary}"/>
                    </Border>

                </HorizontalStackLayout>
            </Border>

            <!-- ===== APPEARANCE CARD ===== -->
            <Border
                BackgroundColor="{DynamicResource CardBackground}"
                Stroke="{DynamicResource CardStroke}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="20,18">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Оформление" FontSize="16" FontAttributes="Bold"
                           TextColor="{DynamicResource TextPrimary}"/>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="40" VerticalOptions="Center">

                        <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <Label Text="Тема приложения" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Выберите тему оформления приложения" FontSize="12"
                                   TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="14" VerticalOptions="Center">

                            <!-- Тёмная -->
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border x:Name="DarkBorder"
                                        WidthRequest="110" HeightRequest="90"
                                        BackgroundColor="#1A1A2E"
                                        Stroke="#4F6FFF" StrokeThickness="2"
                                        StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDarkThemeTapped"/>
                                    </Border.GestureRecognizers>
                                    <Grid>
                                        <Image Source="sundark.png" WidthRequest="40" HeightRequest="40"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Border x:Name="DarkCheckmark"
                                                WidthRequest="24" HeightRequest="24"
                                                BackgroundColor="#4F6FFF" StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                HorizontalOptions="End" VerticalOptions="Start"
                                                Margin="0,8,8,0">
                                            <Label Text="✓" FontSize="13" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Label x:Name="DarkLabel" Text="Тёмная" FontSize="13"
                                       TextColor="White" HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Полночная -->
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Border x:Name="MidnightBorder"
                                        WidthRequest="110" HeightRequest="90"
                                        BackgroundColor="#0D0B1E"
                                        Stroke="#2E2660" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMidnightThemeTapped"/>
                                    </Border.GestureRecognizers>
                                    <Grid>
                                        <!-- Звёздочки для полночного превью -->
                                        <Image Source="midnight.png" HorizontalOptions="Center" VerticalOptions="Center"></Image>
                                        <Border x:Name="MidnightCheckmark"
                                                WidthRequest="24" HeightRequest="24"
                                                BackgroundColor="#6C5CE7" StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                HorizontalOptions="End" VerticalOptions="Start"
                                                Margin="0,8,8,0"
                                                IsVisible="False">
                                            <Label Text="✓" FontSize="13" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Label x:Name="MidnightLabel" Text="Полуночная" FontSize="13"
                                       TextColor="#9B8FCC" HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                        </HorizontalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
