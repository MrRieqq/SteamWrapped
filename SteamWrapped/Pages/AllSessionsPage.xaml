<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.AllSessionsPage"
    Title="Все сессии"
    BackgroundColor="{DynamicResource PageBackground}">

    <CollectionView
        ItemsSource="{Binding Sessions}"
        Margin="20"
        SelectionMode="None">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Grid Padding="0,0,0,12">

                    <Border
                Padding="12"
                BackgroundColor="{DynamicResource GameCard}"
                Stroke="{DynamicResource GameCardStroke}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12">

                        <Border.Shadow>
                            <Shadow
                        Brush="#355CFF"
                        Radius="12"
                        Opacity="0.12"
                        Offset="0,0"/>
                        </Border.Shadow>

                        <Grid
                    ColumnDefinitions="60,*,70"
                    ColumnSpacing="12">

                            <!-- Обложка -->

                            <Border
                        Grid.Column="0"
                        WidthRequest="52"
                        HeightRequest="72"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 8">

                                <Image
                            Source="{Binding ListImageUrl}"
                            Aspect="AspectFill"/>

                            </Border>

                            <!-- Информация -->

                            <VerticalStackLayout
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Spacing="4">

                                <Label
                            Text="{Binding Name}"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{DynamicResource TextPrimary}"
                            LineBreakMode="TailTruncation"/>

                                <Label
                            Text="За последние 2 недели"
                            FontSize="11"
                            TextColor="{DynamicResource GameTextSub2}"/>

                            </VerticalStackLayout>

                            <!-- Часы -->

                            <Label
                        Grid.Column="2"
                        Text="{Binding HoursLast2Weeks,StringFormat='{0} ч.'}"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        FontSize="13"
                        TextColor="{DynamicResource TextPrimary}"/>

                        </Grid>

                    </Border>

                </Grid>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>