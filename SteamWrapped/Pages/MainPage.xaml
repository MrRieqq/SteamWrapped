<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.MainPage"
    Title="Главная"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Заголовок -->
            <VerticalStackLayout Spacing="4">
                <Label Text="🎮 Steam Wrapped"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <Label Text="Твоя игровая статистика"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
            <Entry
                Placeholder="Введите SteamID64"
                Text="{Binding SteamId}" />

            <Button
                Text="Загрузить статистику"
                Command="{Binding LoadSteamDataCommand}" />
            <!-- ГЛАВНЫЙ БЛОК (градиент) -->
            <Border Padding="20"
                    StrokeShape="RoundRectangle 25">

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource Primary}" Offset="0.0"/>
                        <GradientStop Color="{StaticResource Secondary}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="10">

                    <Label Text="🔥 Общее время"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.8"/>

                    <Label Text="{Binding TotalHours}"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Ты в топ 10% игроков 👀"
                           FontSize="14"
                           TextColor="White"/>

                </VerticalStackLayout>

            </Border>

            <!-- СЕТКА КАРТОЧЕК -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                <!-- Жанр -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 20"
                        Padding="15">

                    <Border.Shadow>
                        <Shadow Brush="#22000000"
                                Offset="0,4"
                                Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🎮 Жанр"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"/>

                        <Label Text="{Binding FavoriteGenre}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Месяц -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeShape="RoundRectangle 20"
                        Padding="15">

                    <Border.Shadow>
                        <Shadow Brush="#22000000"
                                Offset="0,4"
                                Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅 Месяц"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"/>

                        <Label Text="Июль"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ТОП ИГРА -->
            <Border BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 20"
                    Padding="15">

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,4"
                            Radius="10"/>
                </Border.Shadow>

                <HorizontalStackLayout Spacing="15">

                    <Label Text="⭐"
                           FontSize="28"/>

                    <VerticalStackLayout>
                        <Label Text="Топ игра"
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}"/>

                        <Label Text="{Binding FavoriteGame}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

            </Border>

            <!-- КНОПКА -->
            <Button 
                Text="Открыть Wrapped 🚀"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="55"
                FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>