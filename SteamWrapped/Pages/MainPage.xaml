<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.MainPage"
    Title="Steam Wrapped"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <!-- HEADER -->

            <VerticalStackLayout Spacing="4">

                <Label
                    Text="🎮 Steam Wrapped"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    Text="Узнай свою игровую статистику"
                    FontSize="14"
                    TextColor="{StaticResource TextSecondary}" />

            </VerticalStackLayout>

            <!-- INPUT -->

            <Border
                BackgroundColor="{StaticResource CardBackground}"
                StrokeShape="RoundRectangle 20"
                Padding="15">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="SteamID64"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}" />

                    <Entry
                        Placeholder="7656119xxxxxxxxxx"
                        Text="{Binding SteamId}" />

                    <Button
                        Text="Загрузить статистику"
                        Command="{Binding LoadSteamDataCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="14"/>

                    <ActivityIndicator
                        IsRunning="{Binding IsLoading}"
                        IsVisible="{Binding IsLoading}"
                        Color="{StaticResource Primary}" />

                </VerticalStackLayout>

            </Border>

            <!-- ERROR -->

            <Label
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                IsVisible="{Binding HasError}" />

            <!-- MAIN CARD -->

            <Border
                Padding="20"
                StrokeShape="RoundRectangle 25">

                <Border.Background>

                    <LinearGradientBrush
                        StartPoint="0,0"
                        EndPoint="1,1">

                        <GradientStop
                            Color="{StaticResource Primary}"
                            Offset="0"/>

                        <GradientStop
                            Color="{StaticResource Secondary}"
                            Offset="1"/>

                    </LinearGradientBrush>

                </Border.Background>

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="🔥 Общее время"
                        FontSize="14"
                        TextColor="White"
                        Opacity="0.8"/>

                    <Label
                        Text="{Binding TotalHours}"
                        FontSize="38"
                        FontAttributes="Bold"
                        TextColor="White"/>

                    <Label
                        Text="{Binding PlayerType}"
                        FontSize="14"
                        TextColor="White"/>

                </VerticalStackLayout>

            </Border>

            <!-- STATS GRID -->

            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="15"
                RowSpacing="15">

                <!-- Genre -->

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 20"
                    Padding="15">

                    <VerticalStackLayout>

                        <Label
                            Text="🎮 Жанр"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                        <Label
                            Text="{Binding FavoriteGenre}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                    </VerticalStackLayout>

                </Border>

                <!-- Games -->

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 20"
                    Padding="15">

                    <VerticalStackLayout>

                        <Label
                            Text="🎲 Игр"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                        <Label
                            Text="{Binding GamesPlayed}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                    </VerticalStackLayout>

                </Border>

                <!-- Achievements -->

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 20"
                    Padding="15">

                    <VerticalStackLayout>

                        <Label
                            Text="🏆 Достижения"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                        <Label
                            Text="{Binding TotalAchievements}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                    </VerticalStackLayout>

                </Border>

                <!-- Rank -->

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeShape="RoundRectangle 20"
                    Padding="15">

                    <VerticalStackLayout>

                        <Label
                            Text="🚀 Ранг"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                        <Label
                            Text="{Binding GamerRank}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                    </VerticalStackLayout>

                </Border>

            </Grid>

            <!-- TOP GAME -->

            <Border
                BackgroundColor="{StaticResource CardBackground}"
                StrokeShape="RoundRectangle 20"
                Padding="15">

                <HorizontalStackLayout Spacing="15">

                    <Label
                        Text="⭐"
                        FontSize="28"/>

                    <VerticalStackLayout>

                        <Label
                            Text="Топ игра"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                        <Label
                            Text="{Binding FavoriteGame}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                    </VerticalStackLayout>

                </HorizontalStackLayout>

            </Border>

            <!-- TOP 3 -->

            <Border
                BackgroundColor="{StaticResource CardBackground}"
                StrokeShape="RoundRectangle 20"
                Padding="15">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="🏅 Топ игр"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="{Binding TopGame1}"
                        FontSize="15"/>

                    <Label
                        Text="{Binding TopGame2}"
                        FontSize="15"/>

                    <Label
                        Text="{Binding TopGame3}"
                        FontSize="15"/>

                </VerticalStackLayout>

            </Border>

            <!-- REPORT BUTTON -->

            <Button
                Text="Посмотреть полный отчёт 🚀"
                Command="{Binding OpenWrappedCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="55"
                FontAttributes="Bold"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>