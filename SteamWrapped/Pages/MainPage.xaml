<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.MainPage"
    BackgroundColor="{DynamicResource PageBackground}">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="{DynamicResource PageBackground}" Offset="0"/>
                <GradientStop Color="{DynamicResource PageBackground}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollView>
            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="10"
                Padding="0,20,0,40">
                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="10">
                    <Label Text="🎮" FontSize="15"/>
                    <Label
                        Text="ТВОЙ ИГРОВОЙ ГОД В ОДНОМ МЕСТЕ"
                        FontSize="16"
                        TextColor="{DynamicResource MainAccent}"/>
                </HorizontalStackLayout>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="-15">
                    <Label
                        Text="STEAM"
                        FontFamily="Orbitionblod"
                        FontSize="82"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{DynamicResource MainAccent2}"/>
                    <Label
                        Text="WRAPPED"
                        FontFamily="Orbitionblod"
                        FontSize="82"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{DynamicResource MainAccent3}"/>
                </VerticalStackLayout>
                <Label
                    WidthRequest="500"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    TextColor="{DynamicResource MainSubText}"
                    Text="Введи Steam ID и узнай всё о своих игровых привычках — часы, жанры, рекорды и многое другое."/>
                <Grid
                    WidthRequest="1200"
                    ColumnDefinitions="550,620"
                    ColumnSpacing="20"
                    HorizontalOptions="Center">

                    <!-- Профиль слева -->
                    <Border
                        Grid.Column="0"
                        BackgroundColor="{DynamicResource MainCard}"
                        Stroke="{DynamicResource MainCardStroke}"
                        StrokeThickness="1"
                        Padding="20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Grid
                            ColumnDefinitions="140,*"
                            ColumnSpacing="20">

                            <!-- Аватар + ник -->
                            <VerticalStackLayout
                                Grid.Column="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="10">
                                <Frame
                                    WidthRequest="110"
                                    HeightRequest="110"
                                    CornerRadius="55"
                                    Padding="0"
                                    BorderColor="#4E8BE0"
                                    IsClippedToBounds="True">
                                    <Image
                                        Source="{Binding AvatarUrl}"
                                        Aspect="AspectFill"/>
                                </Frame>
                                <Label
                                    Text="{Binding PlayerName}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Center"
                                    TextColor="{DynamicResource TextPrimary}"/>
                                <Border
                                    BackgroundColor="{DynamicResource MainCardInner}"
                                    Padding="8,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label
                                        Text="{Binding SteamLevel, StringFormat='Уровень {0}'}"
                                        TextColor="{DynamicResource MainAccent}"
                                        HorizontalTextAlignment="Center"
                                        HorizontalOptions="Fill"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Статистика справа -->
                            <VerticalStackLayout
                                Grid.Column="1"
                                VerticalOptions="Center"
                                Spacing="15">
                                <Label
                                    Text="{Binding TotalHours, StringFormat='⏱ Часы: {0}'}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{DynamicResource TextPrimary}"/>
                                <Label
                                    Text="{Binding GamesPlayed, StringFormat='🎮 Игр: {0}'}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{DynamicResource TextPrimary}"/>
                                <Label
                                    Text="{Binding TotalAchievements, StringFormat='🏆 Достижений: {0}'}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{DynamicResource TextPrimary}"/>
                                <Label
                                    Text="{Binding GamerRank, StringFormat='🚀 Ранг: {0}'}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{DynamicResource MainAccent}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Форма справа -->
                    <Border
                        Grid.Column="1"
                        Padding="35"
                        BackgroundColor="{DynamicResource MainCard2}"
                        Stroke="{DynamicResource MainCard2Stroke}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="25">
                            <Label
                                Text="STEAM ID ИЛИ ССЫЛКА НА ПРОФИЛЬ"
                                FontSize="13"
                                TextColor="{DynamicResource MainSubText2}"/>
                            <Border BackgroundColor="{DynamicResource PageBackground}" Stroke="{DynamicResource MainCardStroke}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry
                                    Placeholder="7656119XXXXXXXXXX или /id/username"
                                    PlaceholderColor="#5E6C80"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BackgroundColor="Transparent"
                                    Margin="20,8"
                                    Text="{Binding SteamId}"/>
                            </Border>
                            <Label
                                FontSize="14"
                                TextColor="{DynamicResource MainSubText2}"
                                Text="Поддерживаются SteamID64 и ссылки на профиль."/>
                            <Button
                                HeightRequest="60"
                                Text="⚡ Загрузить мой профиль"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="{DynamicResource TextPrimary}"
                                CornerRadius="12"
                                Command="{Binding LoadSteamDataCommand}"/>
                            <ActivityIndicator
                                IsRunning="{Binding IsLoading}"
                                IsVisible="{Binding IsLoading}"
                                Color="#53B9FF"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>