<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.Statspage"
    Title=""
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- ===== HEADER ===== -->
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,4">
                <!-- Icon + Title -->
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="10">
                        
                        <Label Text="Статистика" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Обзор вашей игровой активности в Steam" FontSize="13" TextColor="#8A9BB8" />
                </VerticalStackLayout>

                <!-- Dropdown -->
                <Border
                    Grid.Column="2"
                    Padding="14,8"
                    BackgroundColor="#1A2535"
                    Stroke="#263244"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    VerticalOptions="Center"
                    Margin="0,0,0,0">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Все игры" TextColor="White" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="▾" TextColor="#8A9BB8" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- ===== TOP STAT CARDS ===== -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">

                <!-- Общее время -->
                <Border Grid.Column="0" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🕐" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Общее время в играх" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="1 234 ч." FontSize="26" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="≈ 51 день" FontSize="12" TextColor="#8A9BB8"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Всего игр -->
                <Border Grid.Column="1" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🎮" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Всего игр" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="87" FontSize="26" FontAttributes="Bold" TextColor="White"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Всего достижений -->
                <Border Grid.Column="2" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🏆" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Всего достижений" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="324" FontSize="26" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="/ 1 247" FontSize="18" TextColor="#8A9BB8" VerticalOptions="End" Margin="0,0,0,3"/>
                        </HorizontalStackLayout>
                        <ProgressBar Progress="0.26" HeightRequest="5" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                        <Label Text="26% завершено" FontSize="11" TextColor="#8A9BB8"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Среднее время -->
                <Border Grid.Column="3" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="📈" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Среднее время за игру" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="14,2 ч." FontSize="26" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="на одну игру" FontSize="12" TextColor="#8A9BB8"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ===== MIDDLE ROW ===== -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                <!-- LEFT: Самые популярные игры -->
                <Border Grid.Column="0" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Самые популярные игры" FontSize="15" FontAttributes="Bold" TextColor="White" Margin="0,0,0,14"/>

                        <!-- Row 1: Elden Ring -->
                        <Grid ColumnDefinitions="24,44,*,Auto" RowDefinitions="44" ColumnSpacing="10" Margin="0,0,0,10">
                            <Label Grid.Column="0" Text="1" FontSize="13" TextColor="#8A9BB8" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                                <Image Source="eldenring.jpg" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                <Label Text="Elden Ring" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <ProgressBar Progress="1.0" HeightRequest="4" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="187 ч." TextColor="#8A9BB8" FontSize="13" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Row 2: The Witcher 3 -->
                        <Grid ColumnDefinitions="24,44,*,Auto" RowDefinitions="44" ColumnSpacing="10" Margin="0,0,0,10">
                            <Label Grid.Column="0" Text="2" FontSize="13" TextColor="#8A9BB8" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                                <Image Source="witcher3.jpg" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                <Label Text="The Witcher 3: Wild Hunt" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <ProgressBar Progress="0.76" HeightRequest="4" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="142 ч." TextColor="#8A9BB8" FontSize="13" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Row 3: Cyberpunk 2077 -->
                        <Grid ColumnDefinitions="24,44,*,Auto" RowDefinitions="44" ColumnSpacing="10" Margin="0,0,0,10">
                            <Label Grid.Column="0" Text="3" FontSize="13" TextColor="#8A9BB8" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                                <Image Source="cyberpunk.jpg" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                <Label Text="Cyberpunk 2077" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <ProgressBar Progress="0.52" HeightRequest="4" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="98 ч." TextColor="#8A9BB8" FontSize="13" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Row 4: RDR2 -->
                        <Grid ColumnDefinitions="24,44,*,Auto" RowDefinitions="44" ColumnSpacing="10" Margin="0,0,0,10">
                            <Label Grid.Column="0" Text="4" FontSize="13" TextColor="#8A9BB8" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                                <Image Source="rdr2.jpg" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                <Label Text="Red Dead Redemption 2" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <ProgressBar Progress="0.46" HeightRequest="4" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="87 ч." TextColor="#8A9BB8" FontSize="13" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Row 5: Dota 2 -->
                        <Grid ColumnDefinitions="24,44,*,Auto" RowDefinitions="44" ColumnSpacing="10" Margin="0,0,0,14">
                            <Label Grid.Column="0" Text="5" FontSize="13" TextColor="#8A9BB8" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Border Grid.Column="1" WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                                <Image Source="dota2.jpg" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                <Label Text="Dota 2" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <ProgressBar Progress="0.36" HeightRequest="4" ProgressColor="#4F6FFF" BackgroundColor="#1E293B"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="68 ч." TextColor="#8A9BB8" FontSize="13" VerticalOptions="Center"/>
                        </Grid>

                        <!-- All games link -->
                        <BoxView HeightRequest="1" Color="#263244" Margin="0,0,0,10"/>
                        <Label Text="Все игры" FontSize="13" TextColor="#8A9BB8" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- RIGHT: Недавние достижения -->
                <Border Grid.Column="1" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Недавние достижения" FontSize="15" FontAttributes="Bold" TextColor="White" Margin="0,0,0,14"/>

                        <!-- Achievement 1 -->
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                            <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#1A2535">
                                <Label Text="🏆" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Владыка Колец" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="Получить все достижения" TextColor="#8A9BB8" FontSize="12"/>
                                <Label Text="Elden Ring" TextColor="#8A9BB8" FontSize="11"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="2 ч. назад" FontSize="11" TextColor="#8A9BB8" VerticalOptions="Start"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" Margin="0,0,0,14"/>

                        <!-- Achievement 2 -->
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                            <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#1A2535">
                                <Label Text="⚔️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="По следам Цири" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="Завершить основную историю" TextColor="#8A9BB8" FontSize="12"/>
                                <Label Text="The Witcher 3: Wild Hunt" TextColor="#8A9BB8" FontSize="11"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="Вчера" FontSize="11" TextColor="#8A9BB8" VerticalOptions="Start"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" Margin="0,0,0,14"/>

                        <!-- Achievement 3 -->
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                            <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#1A2535">
                                <Label Text="🌟" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Живая легенда" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="Достичь уровня 50" TextColor="#8A9BB8" FontSize="12"/>
                                <Label Text="Cyberpunk 2077" TextColor="#8A9BB8" FontSize="11"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="2 дн. назад" FontSize="11" TextColor="#8A9BB8" VerticalOptions="Start"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#1E293B" Margin="0,0,0,14"/>

                        <!-- Achievement 4 -->
                        <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                            <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#1A2535">
                                <Label Text="🛡️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Выживание любой ценой" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="Пройти 10 волн в выживании" TextColor="#8A9BB8" FontSize="12"/>
                                <Label Text="Vampire Survivors" TextColor="#8A9BB8" FontSize="11"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="3 дн. назад" FontSize="11" TextColor="#8A9BB8" VerticalOptions="Start"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#263244" Margin="0,0,0,10"/>
                        <Label Text="Все достижения" FontSize="13" TextColor="#8A9BB8" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ===== BOTTOM ROW ===== -->
            <Border BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14" HorizontalOptions="Center" WidthRequest="600">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Недавние игровые сессии" FontSize="15" FontAttributes="Bold" TextColor="White" Margin="0,0,0,14"/>

                    <!-- Session header -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,10">
                        <BoxView Grid.Column="0" Color="Transparent"/>
                        <Label Grid.Column="1" Text="" TextColor="#8A9BB8" FontSize="11"/>
                        <Label Grid.Column="2" Text="" TextColor="#8A9BB8" FontSize="11" HorizontalOptions="Center"/>
                        <Label Grid.Column="3" Text="" TextColor="#8A9BB8" FontSize="11" HorizontalOptions="End"/>
                    </Grid>

                    <!-- Session 1: Elden Ring -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,12">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                            <Image Source="eldenring.jpg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Elden Ring" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="Сегодня, 15:24" TextColor="#8A9BB8" FontSize="11"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2" Color="Transparent"/>
                        <Label Grid.Column="3" Text="2 ч. 18 мин." TextColor="#8A9BB8" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Session 2: Cyberpunk -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,12">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                            <Image Source="cyberpunk.jpg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Cyberpunk 2077" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="Вчера, 20:11" TextColor="#8A9BB8" FontSize="11"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2" Color="Transparent"/>
                        <Label Grid.Column="3" Text="1 ч. 45 мин." TextColor="#8A9BB8" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Session 3: Witcher -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,12">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                            <Image Source="witcher3.jpg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="The Witcher 3: Wild Hunt" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="Вчера, 17:32" TextColor="#8A9BB8" FontSize="11"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2" Color="Transparent"/>
                        <Label Grid.Column="3" Text="3 ч. 02 мин." TextColor="#8A9BB8" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Session 4: RDR2 -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,12">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                            <Image Source="rdr2.jpg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Red Dead Redemption 2" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="16 май, 21:47" TextColor="#8A9BB8" FontSize="11"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2" Color="Transparent"/>
                        <Label Grid.Column="3" Text="1 ч. 36 мин." TextColor="#8A9BB8" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <!-- Session 5: Dota 2 -->
                    <Grid ColumnDefinitions="44,*,*,Auto" ColumnSpacing="10" Margin="0,0,0,14">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" StrokeShape="RoundRectangle 8" BackgroundColor="#1E293B">
                            <Image Source="dota2.jpg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Dota 2" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                            <Label Text="15 май, 18:05" TextColor="#8A9BB8" FontSize="11"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="2" Color="Transparent"/>
                        <Label Grid.Column="3" Text="45 мин." TextColor="#8A9BB8" FontSize="12" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#263244" Margin="0,0,0,10"/>
                    <Label Text="Все сессии" FontSize="13" TextColor="#8A9BB8" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>



</ContentPage>