<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.Statspage"
    Title=""
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24,20" Spacing="16">

            <!-- ===== HEADER ===== -->
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,4">
                <!-- Icon + Title -->
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="10">
                        
                        <Label Text="Статистика" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Обзор вашей игровой активности в Steam" FontSize="13" TextColor="#8A9BB8" />
                </VerticalStackLayout>

                <!-- Dropdown -->
                <Border
                    Grid.Column="2"
                    Padding="14,8"
                    BackgroundColor="#1A2535"
                    Stroke="#263244"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    VerticalOptions="Center"
                    Margin="0,0,0,0">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Все игры" TextColor="White" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="▾" TextColor="#8A9BB8" FontSize="14" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- ===== TOP STAT CARDS ===== -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">

                <!-- Общее время -->
                <Border Grid.Column="0" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🕐" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Общее время в играх" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding TotalHoursText}"
       FontSize="26"
       FontAttributes="Bold"
       TextColor="White"/>

                        <Label Text="{Binding TotalDaysText}"
       FontSize="12"
       TextColor="#8A9BB8"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Всего игр -->
                <Border Grid.Column="1" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🎮" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Всего игр" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding TotalGames}"
       FontSize="26"
       FontAttributes="Bold"
       TextColor="White"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Всего достижений -->
                <Border Grid.Column="2" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="🏆" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Всего достижений" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding UnlockedAchievements}" />

                            <Label Text="{Binding TotalAchievements,
              StringFormat='/ {0}'}" />
                        </HorizontalStackLayout>
                        <ProgressBar Progress="{Binding AchievementProgress}" />

                        <Label Text="{Binding AchievementPercentText}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Среднее время -->
                <Border Grid.Column="3" BackgroundColor="#111827" Stroke="#263244" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="16,14">
                    <VerticalStackLayout Spacing="6">
                        <HorizontalStackLayout Spacing="8">
                            <Border WidthRequest="32" HeightRequest="32" BackgroundColor="#1E2D45" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                <Label Text="📈" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Среднее время за игру" FontSize="12" TextColor="#8A9BB8" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding AverageHoursText}"
       FontSize="26"
       FontAttributes="Bold"
       TextColor="White"/>

                        <ProgressBar Progress="{Binding AchievementProgress}"
             HeightRequest="5"
             ProgressColor="#4F6FFF"
             BackgroundColor="#1E293B"/>

                        <Label Text="{Binding AchievementPercentText}"
       FontSize="11"
       TextColor="#8A9BB8"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ===== MIDDLE ROW ===== -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border
    Grid.Column="0"
    BackgroundColor="#111827"
    Stroke="#263244"
    StrokeThickness="1"
    StrokeShape="RoundRectangle 14">

                    <Grid RowDefinitions="Auto,*,Auto">

                        <Label
            Grid.Row="0"
            Text="Самые популярные игры"
            Margin="16,16,16,12"
            FontSize="15"
            FontAttributes="Bold"
            TextColor="White"/>

                        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding TopGames}"
            SelectionMode="None"
            Margin="16,0">

                            <CollectionView.ItemTemplate>

                                <DataTemplate>
                                    <Border
        StrokeThickness="0"
        Margin="0,0,0,16">

                                        <Grid
                        ColumnDefinitions="30,60,*,70"
                        ColumnSpacing="12"
                        Margin="0,0,0,18">

                                            <Label
                            Grid.Column="0"
                            Text="{Binding Rank}"
                            TextColor="#8A9BB8"
                            FontSize="14"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                                            <Border
                            Grid.Column="1"
                            WidthRequest="52"
                            HeightRequest="52"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8">

                                                <Image
                                Source="{Binding ListImageUrl}"
                                Aspect="AspectFill"/>

                                            </Border>

                                            <VerticalStackLayout
                            Grid.Column="2"
                            VerticalOptions="Center"
                            Spacing="6">

                                                <Label
                                Text="{Binding Name}"
                                FontAttributes="Bold"
                                FontSize="14"
                                TextColor="White"
                                LineBreakMode="TailTruncation"/>

                                                <ProgressBar
                                Progress="{Binding PlaytimeProgress}"
                                HeightRequest="4"
                                ProgressColor="#4F6FFF"
                                BackgroundColor="#1E293B"/>

                                            </VerticalStackLayout>

                                            <Label
                            Grid.Column="3"
                            Text="{Binding HoursPlayed,StringFormat='{0} ч.'}"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            TextColor="#8A9BB8"
                            FontSize="13"/>

                                        </Grid>
                                    </Border>
                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <Grid
            Grid.Row="2"
            HeightRequest="50">

                            <BoxView
                HeightRequest="1"
                Color="#263244"
                VerticalOptions="Start"/>

                            <Label
                Text="Все игры"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TextColor="#8A9BB8">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                        Command="{Binding OpenAllGamesCommand}" />
                                </Label.GestureRecognizers>

                            </Label>

                        </Grid>

                    </Grid>

                </Border>
                <!-- RIGHT: Недавние достижения -->
                <Border
Grid.Column="1"
BackgroundColor="#111827"
Stroke="#263244"
StrokeThickness="1"
StrokeShape="RoundRectangle 14">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <!-- Заголовок -->
                        <Label Grid.Row="0" Text="Недавние достижения" Margin="16,16,16,12" FontSize="15" FontAttributes="Bold" TextColor="White"/>
                        <!-- Список достижений -->
                        <CollectionView Grid.Row="1" ItemsSource="{Binding RecentAchievements}" SelectionMode="None" Margin="16,0">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="0" Margin="0,0,0,16">
                                        <Grid ColumnDefinitions="30,60,*,70" ColumnSpacing="12" Margin="0,0,0,18">
                                            <!-- Номер -->
                                            <Label Grid.Column="0" Text="" TextColor="#8A9BB8" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            <!-- Картинка -->
                                            <Border Grid.Column="1" WidthRequest="52" HeightRequest="52" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                                                <Image Source="{Binding ListImageUrl}" Aspect="AspectFill"/>
                                            </Border>
                                            <!-- Информация -->
                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="4">
                                                <Label Text="{Binding AchievementName}" FontAttributes="Bold" FontSize="14" TextColor="White" LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding Description}" FontSize="11" TextColor="#C7D5E0" MaxLines="2" LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding GameName}" FontSize="11" TextColor="#8A9BB8" LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                            <!-- Дата -->
                                            <Label Grid.Column="3" Text="{Binding UnlockDate,StringFormat='{0:dd.MM}'}" HorizontalOptions="End" VerticalOptions="Center" TextColor="#8A9BB8" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <!-- Нижняя кнопка -->
                        <Grid Grid.Row="2" HeightRequest="50">
                            <BoxView HeightRequest="1" Color="#263244" VerticalOptions="Start"/>
                            <Label
    Text="Все достижения"
    HorizontalOptions="Center"
    VerticalOptions="Center"
    TextColor="#8A9BB8">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
            Command="{Binding OpenAllAchievementsCommand}" />
                                </Label.GestureRecognizers>

                            </Label>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== BOTTOM ROW ===== -->
            <Border
    BackgroundColor="#111827"
    Stroke="#263244"
    StrokeThickness="1"
    StrokeShape="RoundRectangle 14">

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Заголовок -->
                    <Label
            Grid.Row="0"
            Text="Недавние игровые сессии"
            Margin="16,16,16,12"
            FontSize="15"
            FontAttributes="Bold"
            TextColor="White"/>

                    <!-- Список -->
                    <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding RecentGames}"
            SelectionMode="None"
            Margin="16,0">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <Border
            StrokeThickness="0"
            Margin="0,0,0,16">

                                    <Grid
                ColumnDefinitions="30,60,*,70"
                ColumnSpacing="12"
                Margin="0,0,0,18">

                                        <!-- Пустая колонка как в популярных играх -->
                                        <Label
    Grid.Column="0"
    Text="{Binding Rank}"
    TextColor="#8A9BB8"
    FontSize="14"
    HorizontalOptions="Center"
    VerticalOptions="Center"/>

                                        <!-- Обложка -->
                                        <Border
                    Grid.Column="1"
                    WidthRequest="52"
                    HeightRequest="52"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">

                                            <Image
    Source="{Binding ListImageUrl}"
    Aspect="AspectFill"/>

                                        </Border>

                                        <!-- Информация -->
                                        <VerticalStackLayout
                    Grid.Column="2"
                    VerticalOptions="Center"
                    Spacing="4">

                                            <Label
                        Text="{Binding Name}"
                        FontAttributes="Bold"
                        FontSize="14"
                        TextColor="White"
                        LineBreakMode="TailTruncation"/>

                                            <Label
                        Text="За последние 2 недели"
                        FontSize="11"
                        TextColor="#8A9BB8"/>

                                        </VerticalStackLayout>

                                        <!-- Часы -->
                                        <Label
                    Grid.Column="3"
                    Text="{Binding HoursLast2Weeks,StringFormat='{0} ч.'}"
                    HorizontalOptions="End"
                    VerticalOptions="Center"
                    TextColor="#8A9BB8"
                    FontSize="13"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <!-- Кнопка -->
                    <Grid
            Grid.Row="2"
            HeightRequest="50">

                        <BoxView
                HeightRequest="1"
                Color="#263244"
                VerticalOptions="Start"/>

                        <Label
                Text="Все сессии"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TextColor="#8A9BB8"/>

                    </Grid>

                </Grid>

            </Border>
        </VerticalStackLayout>
    </ScrollView>



</ContentPage>