<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.AlAchievementsPage"
    Title="Все достижения"
    BackgroundColor="{DynamicResource PageBackground}">

    <CollectionView
        ItemsSource="{Binding Achievements}"
        Margin="20">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Border
                    BackgroundColor="{DynamicResource CardBackground}"
                    Stroke="{DynamicResource CardStroke}"
                    StrokeShape="RoundRectangle 12"
                    Padding="12"
                    Margin="0,0,0,12">

                    <Grid
                        ColumnDefinitions="60,*,70"
                        ColumnSpacing="12">

                        <Border
                            WidthRequest="52"
                            HeightRequest="52"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8">

                            <Image
                                Source="{Binding ListImageUrl}"
                                Aspect="AspectFill"/>

                        </Border>

                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="4">

                            <Label
                                Text="{Binding AchievementName}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{DynamicResource TextPrimary}"/>

                            <Label
                                Text="{Binding Description}"
                                FontSize="12"
                                TextColor="#C7D5E0"/>

                            <Label
                                Text="{Binding GameName}"
                                FontSize="11"
                                TextColor="{DynamicResource TextSecondary}"/>

                        </VerticalStackLayout>

                        <Label
                            Grid.Column="2"
                            Text="{Binding UnlockDate,StringFormat='{0:dd.MM.yyyy}'}"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            TextColor="{DynamicResource TextSecondary}"/>

                    </Grid>

                </Border>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>