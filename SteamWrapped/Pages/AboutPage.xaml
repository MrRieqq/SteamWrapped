<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.AboutPage"
    Title="О приложении"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="20">

            <!-- ===== HEADER ===== -->
            <VerticalStackLayout Spacing="2" Margin="0,0,0,4">
                <Label Text="О приложении" FontSize="26" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                <Label Text="Информация о приложении SteamWrapped" FontSize="13" TextColor="{DynamicResource TextSecondary}"/>
            </VerticalStackLayout>

            <!-- ===== PROFILE CARD ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}" Stroke="{DynamicResource CardStroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                <VerticalStackLayout Spacing="0">

                    <Grid ColumnDefinitions="80,*" ColumnSpacing="16" Margin="0,0,0,16">
                        <Border WidthRequest="80" HeightRequest="80" StrokeThickness="2" Stroke="#6A3DE8" StrokeShape="Ellipse" BackgroundColor="#1A1A2E">
                            <Image Source="logo.png" Aspect="AspectFit" Margin="0"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="SteamWrapped" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Аналитика вашей игровой активности в Steam" FontSize="12" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource Divider}" Margin="0,0,0,12"/>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <Label Text="Версия приложения" FontSize="13" TextColor="{DynamicResource TextSecondary}"/>
                        <Label Grid.Column="1" Text="1.2.0" FontSize="13" TextColor="{DynamicResource TextPrimary}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <Label Text="Сборка" FontSize="13" TextColor="{DynamicResource TextSecondary}"/>
                        <Label Grid.Column="1" Text="120" FontSize="13" TextColor="{DynamicResource TextPrimary}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Дата установки" FontSize="13" TextColor="{DynamicResource TextSecondary}"/>
                        <Label Grid.Column="1" Text="15 мая 2024 г." FontSize="13" TextColor="{DynamicResource TextPrimary}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ===== О ПРИЛОЖЕНИИ ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}" Stroke="{DynamicResource CardStroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                <VerticalStackLayout Spacing="14">
                    <Label Text="О приложении" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                    <Label FontSize="13" TextColor="{DynamicResource TextSecondary}" LineBreakMode="WordWrap">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="SteamWrapped" TextColor="{DynamicResource TextPrimary}" FontAttributes="Bold"/>
                                <Span Text=" помогает вам анализировать вашу игровую активность в Steam. Отслеживайте время в играх, достижения, любимые жанры и многое другое." TextColor="{DynamicResource TextSecondary}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">

                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="8">
                            <Border WidthRequest="54" HeightRequest="54" BackgroundColor="{DynamicResource CardInner2}" StrokeThickness="0" StrokeShape="RoundRectangle 14" HorizontalOptions="Center">
                                <Image Source="static.png" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Детальная&#10;статистика" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8">
                            <Border WidthRequest="54" HeightRequest="54" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 14" HorizontalOptions="Center">
                                <Image Source="achivets.png" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Достижения&#10;и прогресс" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="8">
                            <Border WidthRequest="54" HeightRequest="54" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 14" HorizontalOptions="Center">
                                <Image Source="analitikas.png" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Аналитика&#10;по играм" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="8">
                            <Border WidthRequest="54" HeightRequest="54" BackgroundColor="{DynamicResource CardInner2}" StrokeThickness="0" StrokeShape="RoundRectangle 14" HorizontalOptions="Center">
                                <Image Source="cartochki.png" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Красивые&#10;карточки" FontSize="11" TextColor="{DynamicResource TextSecondary}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ===== ТЕХНОЛОГИИ ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}" Stroke="{DynamicResource CardStroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Технологии" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                    <!-- Steam Web API -->
                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                        <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <Image Source="steam.png" Aspect="AspectFit" Margin="4"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Steam Web API" FontSize="13" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Информация о вашем профиле и играх" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Перейти на сайт " TextColor="#6A5ACD" FontSize="12"/>
                                    <Span Text="↗" TextColor="#6A5ACD" FontSize="12"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenSteamApiCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource CardInner3}" Margin="0,0,0,14"/>

                    <!-- .NET MAUI -->
                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <Label Text=".NET" FontSize="11" FontAttributes="Bold" TextColor="#512BD4" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text=".NET MAUI" FontSize="13" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Фреймворк для создания приложений" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Перейти на сайт " TextColor="#6A5ACD" FontSize="12"/>
                                    <Span Text="↗" TextColor="#6A5ACD" FontSize="12"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenMauiCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ===== ПОДДЕРЖКА ===== -->
            <Border BackgroundColor="{DynamicResource CardBackground}" Stroke="{DynamicResource CardStroke}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Поддержка" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                    <!-- FAQ -->
                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12" Margin="0,0,0,14">
                        <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <Image Source="tgph.png" HorizontalOptions="Center" VerticalOptions="Center"></Image>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Часто задаваемые вопросы" FontSize="13" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Ответы на популярные вопросы" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Перейти к FAQ" TextColor="#6A5ACD" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenFaqCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource CardInner3}" Margin="0,0,0,14"/>

                    <!-- Связаться с нами -->
                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource CardInner}" StrokeThickness="0" StrokeShape="RoundRectangle 8">
                            <Image Source="github.png" HorizontalOptions="Center" VerticalOptions="Center"></Image>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Связаться с нами" FontSize="13" FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}"/>
                            <Label Text="Написать в службу поддержки" FontSize="11" TextColor="{DynamicResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="Написать" TextColor="#6A5ACD" FontSize="12" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenGitCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ===== FOOTER ===== -->
            <Label
                Text="© 2024 SteamWrapped. Все права защищены."
                FontSize="12"
                TextColor="{DynamicResource TextSecondary}"
                HorizontalOptions="Center"
                Margin="0,0,0,10"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
