<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.GamesPage"
    BackgroundColor="#1B2838">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Заголовок -->
        <VerticalStackLayout
            Grid.Row="0"
            Padding="25,20,25,15"
            Spacing="3">

            <Label
                Text="МОИ ИГРЫ"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="White"/>

            <Label
                Text="Библиотека Steam"
                FontSize="14"
                TextColor="#8F98A0"/>

        </VerticalStackLayout>

        <!-- Поиск -->
        <Border
            Grid.Row="1"
            Margin="25,0,25,20"
            BackgroundColor="#2A475E"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10">

            <Grid
                Padding="15,10"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10">

                <Label
                    Text="🔍"
                    FontSize="18"
                    VerticalOptions="Center"/>

                <Entry
                    Grid.Column="1"
                    Placeholder="Поиск игры..."
                    PlaceholderColor="#8F98A0"
                    TextColor="White"
                    BackgroundColor="Transparent"/>

            </Grid>

        </Border>

        <!-- Список игр -->
        <CollectionView
            Grid.Row="2"
            Margin="25,0"
            SelectionMode="None">

            <CollectionView.ItemsLayout>
                <GridItemsLayout
                    Orientation="Vertical"
                    Span="6"
                    HorizontalItemSpacing="18"
                    VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>Hades</x:String>
                    <x:String>The Long Dark</x:String>
                    <x:String>Cyberpunk 2077</x:String>
                    <x:String>OutDrive</x:String>
                    <x:String>Little Nightmares</x:String>
                    <x:String>Rain World</x:String>
                    <x:String>Robo Instructus</x:String>
                    <x:String>Sekiro</x:String>
                    <x:String>Slay the Spire</x:String>
                    <x:String>Dead Cells</x:String>
                    <x:String>Terraria</x:String>
                    <x:String>Portal 2</x:String>
                    <x:String>Half-Life</x:String>
                    <x:String>Half-Life 2</x:String>
                    <x:String>Doom Eternal</x:String>
                    <x:String>Stardew Valley</x:String>
                    <x:String>CS2</x:String>
                    <x:String>Red Dead Redemption 2</x:String>
                </x:Array>
            </CollectionView.ItemsSource>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                        WidthRequest="160"
                        HeightRequest="240"
                        BackgroundColor="#101822"
                        StrokeThickness="0">

                        <Border.Shadow>
                            <Shadow
                                Brush="#80000000"
                                Offset="0,5"
                                Radius="10"/>
                        </Border.Shadow>

                        <Grid>

                            <!-- Заглушка для будущей картинки -->
                            <Border
                                BackgroundColor="#2A475E"
                                StrokeThickness="0">

                                <VerticalStackLayout
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">

                                    <Label
                                        Text="🎮"
                                        FontSize="50"
                                        HorizontalOptions="Center"/>

                                </VerticalStackLayout>

                            </Border>

                            <!-- Нижняя панель -->
                            <Border
                                VerticalOptions="End"
                                HeightRequest="60"
                                BackgroundColor="#CC171A21"
                                StrokeThickness="0">

                                <VerticalStackLayout
                                    Padding="10,7"
                                    Spacing="2">

                                    <Label
                                        Text="{Binding .}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        LineBreakMode="TailTruncation"/>

                                    <Label
                                        Text="148 часов"
                                        FontSize="12"
                                        TextColor="#B8B6B4"/>

                                </VerticalStackLayout>

                            </Border>

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>