<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:SteamWrapped.Converters"
    x:Class="SteamWrapped.Pages.GamesPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource PageBackground}" Offset="0"/>
            <GradientStop Color="{DynamicResource PageBackground}" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:FilterBackgroundConverter
            x:Key="FilterBackgroundConverter"/>
            <converters:FilterTextConverter
            x:Key="FilterTextConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="16,24,16,0" RowDefinitions="Auto,Auto,*">

        <!-- HEADER -->

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,20">
            <Label Text="Ваши игры"
                   FontSize="38"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}"
                   VerticalOptions="Center"/>
            <Border Grid.Column="1"
                    WidthRequest="290"
                    HeightRequest="46"
                    Margin="0,0,12,0"
                    BackgroundColor="{DynamicResource GameSearchBg}"
                    Stroke="{DynamicResource GameCardStroke}"
                    StrokeShape="RoundRectangle 12">
                <Grid ColumnDefinitions="Auto,*"
                      Padding="12,0">
                    <Label Text="🔍"
                           FontSize="15"
                           TextColor="{DynamicResource GameTextSub}"
                           VerticalOptions="Center"
                           Margin="0,0,10,0"/>
                    <Entry
                        Grid.Column="1"
                        Placeholder="Поиск игр..."
                        PlaceholderColor="#7E8AA4"
                        Text="{Binding SearchText}"
                        TextColor="{DynamicResource TextPrimary}"
                        BackgroundColor="Transparent"/>
                </Grid>
            </Border>

        </Grid>

        <!-- FILTERS -->

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,24">

            <!-- ФИЛЬТРЫ -->

            <HorizontalStackLayout Spacing="10">

                <!-- Все игры -->

                <Border Padding="12,6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=Все игры}"
                        HeightRequest="35">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowAllCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Все игры"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Все игры}"/>
                        <Label Text="{Binding TotalGamesCount}"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Все игры}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Недавние -->

                <Border Padding="12,6"
                        Stroke="{DynamicResource GameCardStroke}"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=Недавние}"
                        HeightRequest="35">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowRecentCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Недавние"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Недавние}"/>
                        <Label Text="{Binding RecentGamesCount}"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Недавние}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Избранное -->

                <Border Padding="12,6"
                        Stroke="{DynamicResource GameCardStroke}"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=Избранное}"
                        HeightRequest="35">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowFavoritesCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Избранное"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Избранное}"/>
                        <Label Text="{Binding FavoriteGamesCount}"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Избранное}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Пройденные -->

                <Border Padding="12,6"
                        Stroke="{DynamicResource GameCardStroke}"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=Пройденные}"
                        HeightRequest="35">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowCompletedCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Пройденные"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Пройденные}"/>
                        <Label Text="{Binding CompletedGamesCount}"
                               FontSize="13"
                               TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=Пройденные}"/>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <!-- СОРТИРОВКА -->

            <HorizontalStackLayout Grid.Column="1"
                       Spacing="10"
                       HeightRequest="35"
                       VerticalOptions="Center">

                <!-- Picker-кнопка -->

                <Border BackgroundColor="{DynamicResource GameSearchBg}"
                        Stroke="{DynamicResource GameCardStroke}"
                        StrokeShape="RoundRectangle 10"
                        HeightRequest="35"
                        Padding="10,0">
                    <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                        <Label Text="Сортировка"
                               TextColor="{DynamicResource GameTextSub2}"
                               FontSize="14"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding SortOptions}"
                                SelectedItem="{Binding SelectedSort}"
                                TextColor="{DynamicResource TextPrimary}"
                                BackgroundColor="Transparent"
                                VerticalOptions="Center"
                                HorizontalOptions="Fill"/>
                    </Grid>
                </Border>

                <!-- Вид плиткой -->

                <Border WidthRequest="36"
                        HeightRequest="36"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#355CFF">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsGridView}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="#121B2B"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetGridViewCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="⊞"
                           TextColor="{DynamicResource TextPrimary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsGridView}" Value="False">
                                <Setter Property="TextColor" Value="#8D9AB4"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Вид списком -->

                <Border WidthRequest="36"
                        HeightRequest="36"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{DynamicResource GameSearchBg}">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsGridView}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="#355CFF"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetListViewCommand}" Tapped="FilterButtonTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="≡"
                           TextColor="{DynamicResource GameTextSub2}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsGridView}"
                                         Value="False">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <!-- GAMES -->

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Games}"
                        SelectionMode="None"
                        IsVisible="{Binding IsGridView}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout
                    Orientation="Vertical"
                    Span="5"
                    HorizontalItemSpacing="10"
                    VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border WidthRequest="260"
                            HeightRequest="285"
                            Margin="12"
                            BackgroundColor="{DynamicResource GameCard}"
                            Stroke="{DynamicResource GameCardStroke}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">
                        <Border.Shadow>
                            <Shadow Brush="#355CFF"
                                    Radius="18"
                                    Opacity="0.15"
                                    Offset="0,0"/>
                        </Border.Shadow>
                        <Grid RowDefinitions="145,140">

                            <!-- ОБЛОЖКА -->

                            <Image Grid.Row="0"
                                   Source="{Binding ImageUrl}"
                                   Aspect="AspectFill"/>

                            <!-- ИНФА -->

                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="12"
                                                 Spacing="8">
                                <Label Text="{Binding Name}"
                                       TextColor="{DynamicResource TextPrimary}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding HoursPlayed,StringFormat='{0} ч.'}"
                                           TextColor="{DynamicResource GameTextSub3}"
                                           FontSize="13"/>
                                    <Border BackgroundColor="{DynamicResource GameCardInner}"
                                            StrokeThickness="0"
                                            Padding="8,2">
                                        <Label Text="{Binding Genre}"
                                               TextColor="{DynamicResource TextPrimary}"
                                               FontSize="11"/>
                                    </Border>
                                </HorizontalStackLayout>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding AchievementText}"
                                           TextColor="#FFD54F"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding AchievementPercentText}"
                                           TextColor="{DynamicResource TextPrimary}"/>
                                </Grid>
                                <ProgressBar Progress="{Binding AchievementPercent}"
                                             IsVisible="{Binding HasAchievements}"
                                             ProgressColor="#4C7CFF"
                                             HeightRequest="6"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <CollectionView Grid.Row="2"
                ItemsSource="{Binding Games}"
                SelectionMode="None"
                IsVisible="{Binding IsListView}">
            <CollectionView.Header>
                <Grid ColumnDefinitions="4*,2*,1.5*" Margin="12,0,12,12">
                    <Label Text="Название" TextColor="{DynamicResource GameTextSub2}"/>
                    <Label Grid.Column="1"
                           Text="Достижения"
                           HorizontalTextAlignment="Center"
                           TextColor="{DynamicResource GameTextSub2}"/>
                    <Label Grid.Column="2"
                           Text="Сыгранное время"
                           HorizontalTextAlignment="Center"
                           TextColor="{DynamicResource GameTextSub2}"/>
                </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Grid Padding="0,0,0,12">
                        <Border
                            Padding="12"
                            BackgroundColor="{DynamicResource GameCard}"
                            Stroke="{DynamicResource GameCardStroke}"
                            StrokeShape="RoundRectangle 12">

                            <Grid ColumnDefinitions="4*,2*,1.5*">

                                <!-- Игра -->

                                <HorizontalStackLayout Spacing="12">
                                    <Image Source="{Binding ListImageUrl}"
                                           WidthRequest="56"
                                           HeightRequest="84"
                                           Aspect="AspectFill"/>
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource TextPrimary}"/>
                                        <Label Text="{Binding Genre}"
                                               FontSize="12"
                                               TextColor="{DynamicResource GameTextSub2}"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Достижения -->
                                <Grid Grid.Column="1"
                                  Padding="12,0"
                                  VerticalOptions="Center">
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding AchievementText}"
                                                   TextColor="#FFD54F"
                                                   FontSize="12"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding AchievementPercentText}"
                                                   TextColor="{DynamicResource TextPrimary}"
                                                   FontSize="12"/>
                                        </Grid>
                                        <ProgressBar Progress="{Binding AchievementPercent}"
                                                     ProgressColor="#4C7CFF"
                                                     HeightRequest="5"
                                                     IsVisible="{Binding HasAchievements}"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Время -->

                                <Label Grid.Column="2"
                                   Text="{Binding HoursPlayed,StringFormat='{0} ч.'}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource TextPrimary}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>