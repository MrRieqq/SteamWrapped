<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SteamWrapped.Pages.GamesPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050A14" Offset="0"/>
            <GradientStop Color="#0D1525" Offset="1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid Padding="16,24,16,0"
          RowDefinitions="Auto,Auto,*">

        <!-- HEADER -->

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              Margin="0,0,0,20">

            <Label Text="Мои игры"
                   FontSize="38"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"/>

            <Border Grid.Column="1"
                    WidthRequest="290"
                    HeightRequest="46"
                    Margin="0,0,12,0"
                    BackgroundColor="#121B2B"
                    Stroke="#1F2B40"
                    StrokeShape="RoundRectangle 12">

                <Grid ColumnDefinitions="Auto,*"
                      Padding="12,0">

                    <Label Text="🔍"
                           FontSize="15"
                           TextColor="#7E8AA4"
                           VerticalOptions="Center"/>

                    <Entry Grid.Column="1"
                           Placeholder="Поиск игр..."
                           PlaceholderColor="#7E8AA4"
                           TextColor="White"
                           BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    WidthRequest="46"
                    HeightRequest="46"
                    BackgroundColor="#121B2B"
                    Stroke="#1F2B40"
                    StrokeShape="RoundRectangle 12">

                <Label Text="⚙"
                       FontSize="18"
                       TextColor="#A4B1C8"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

        </Grid>

        <!-- FILTERS -->

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              Margin="0,0,0,24">

            <HorizontalStackLayout Spacing="10">

                <Border Padding="18,10"
                        BackgroundColor="#355CFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Все игры"
                               TextColor="White"
                               FontAttributes="Bold"/>

                        <Label Text="24"
                               TextColor="White"/>
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="18,10"
                        BackgroundColor="#121B2B"
                        Stroke="#1F2B40"
                        StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Недавние"
                               TextColor="#9FB0CC"/>

                        <Label Text="8"
                               TextColor="#9FB0CC"/>
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="18,10"
                        BackgroundColor="#121B2B"
                        Stroke="#1F2B40"
                        StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Избранное"
                               TextColor="#9FB0CC"/>

                        <Label Text="12"
                               TextColor="#9FB0CC"/>
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="18,10"
                        BackgroundColor="#121B2B"
                        Stroke="#1F2B40"
                        StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="Пройденные"
                               TextColor="#9FB0CC"/>

                        <Label Text="7"
                               TextColor="#9FB0CC"/>
                    </HorizontalStackLayout>
                </Border>

            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="10">

                <Border Padding="16,10"
                        BackgroundColor="#121B2B"
                        Stroke="#1F2B40"
                        StrokeShape="RoundRectangle 12">

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Сортировка:"
                               TextColor="#8D9AB4"/>

                        <Label Text="По алфавиту"
                               TextColor="White"/>

                        <Label Text="▾"
                               TextColor="#8D9AB4"/>
                    </HorizontalStackLayout>
                </Border>

                <Border WidthRequest="44"
                        HeightRequest="44"
                        BackgroundColor="#355CFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">

                    <Label Text="⊞"
                           TextColor="White"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Border WidthRequest="44"
                        HeightRequest="44"
                        BackgroundColor="#121B2B"
                        Stroke="#1F2B40"
                        StrokeShape="RoundRectangle 12">

                    <Label Text="≡"
                           TextColor="#8D9AB4"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </HorizontalStackLayout>

        </Grid>

        <!-- GAMES -->

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Games}"
                        SelectionMode="None">

            <CollectionView.ItemsLayout>
                <GridItemsLayout
                    Orientation="Vertical"
                    Span="4"
                    HorizontalItemSpacing="20"
                    VerticalItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border WidthRequest="260"
                            HeightRequest="285"
                            Margin="12"
                            BackgroundColor="#101827"
                            Stroke="#1F2B40"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">

                        <Border.Shadow>
                            <Shadow Brush="#355CFF"
                                    Radius="18"
                                    Opacity="0.15"
                                    Offset="0,0"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="145,140">

                            <!-- ОБЛОЖКА -->
                            <Image Grid.Row="0"
           Source="{Binding ImageUrl}"
           Aspect="AspectFill"/>

                            <!-- ИНФА -->
                            <VerticalStackLayout Grid.Row="1"
                         Padding="12"
                         Spacing="8">

                                <Label Text="{Binding Name}"
               TextColor="White"
               FontSize="18"
               FontAttributes="Bold"/>

                                <HorizontalStackLayout Spacing="8">

                                    <Label Text="{Binding HoursPlayed,StringFormat='{0} ч.'}"
                   TextColor="#9FB0CC"
                   FontSize="13"/>

                                    <Border BackgroundColor="#1A2437"
                    StrokeThickness="0"
                    Padding="8,2">

                                        <Label Text="{Binding Genre}"
                       TextColor="White"
                       FontSize="11"/>
                                    </Border>

                                </HorizontalStackLayout>

                                <Grid ColumnDefinitions="*,Auto">

                                    <Label Text="{Binding AchievementText}"
                   TextColor="#FFD54F"/>

                                    <Label Grid.Column="1"
                   Text="{Binding AchievementPercentText}"
                   TextColor="White"/>
                                </Grid>

                                <ProgressBar Progress="{Binding AchievementPercent}"
                                             IsVisible="{Binding HasAchievements}"
                                             ProgressColor="#4C7CFF"
                                             HeightRequest="6"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>