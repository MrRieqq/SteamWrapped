<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SteamWrapped.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:SteamWrapped.Pages"
    Shell.NavBarIsVisible="False">
    

    <Shell.Resources>
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="White"/>
        </Style>
    </Shell.Resources>

    <FlyoutItem Title="Главная" Icon="main.png">
        <ShellContent
            ContentTemplate="{DataTemplate pages:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Ваши игры" Icon="steam2.png">
        <ShellContent
        Route="gamespage"
        ContentTemplate="{DataTemplate pages:GamesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Статистика" Icon="stats.png">
        <ShellContent
            Route="allsessionspage"
            ContentTemplate="{DataTemplate pages:Statspage}" />
    </FlyoutItem>

    <FlyoutItem Title="Настройки" Icon="settings.png">
        <ShellContent
            ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="О приложении" Icon="about.png">
        <ShellContent
            ContentTemplate="{DataTemplate pages:AboutPage}" />
    </FlyoutItem>

</Shell>