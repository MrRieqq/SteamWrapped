<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#66C0F4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#2196F3</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    <Color x:Key="Accent">#FF9800</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="Danger">#E53935</Color>
    <Color x:Key="Background">#101822</Color>

    <!-- ═══ Dynamic theme keys (default = dark) ═══ -->
    <Color x:Key="PageBackground">#0F1923</Color>
    <Color x:Key="CardBackground">#111827</Color>
    <Color x:Key="CardInner">#1A2535</Color>
    <Color x:Key="CardInner2">#1E2D45</Color>
    <Color x:Key="CardInner3">#1E293B</Color>
    <Color x:Key="CardStroke">#263244</Color>
    <Color x:Key="Divider">#263244</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#8A9BB8</Color>
    <Color x:Key="ShellBackground">#171A21</Color>
    <!-- MainPage cards -->
    <Color x:Key="MainCard">#0D1726</Color>
    <Color x:Key="MainCardStroke">#1D3350</Color>
    <Color x:Key="MainCardInner">#132033</Color>
    <Color x:Key="MainCard2">#09111D</Color>
    <Color x:Key="MainCard2Stroke">#1A2A40</Color>
    <Color x:Key="MainAccent">#53B9FF</Color>
    <Color x:Key="MainAccent2">#B9E4FF</Color>
    <Color x:Key="MainAccent3">#8B79FF</Color>
    <Color x:Key="MainSubText">#7E8DA2</Color>
    <Color x:Key="MainSubText2">#6F8198</Color>
    <!-- GamesPage cards -->
    <Color x:Key="GameCard">#101827</Color>
    <Color x:Key="GameCardStroke">#1F2B40</Color>
    <Color x:Key="GameCardInner">#1A2437</Color>
    <Color x:Key="GameSearchBg">#121B2B</Color>
    <Color x:Key="GameTextSub">#7E8AA4</Color>
    <Color x:Key="GameTextSub2">#8D9AB4</Color>
    <Color x:Key="GameTextSub3">#9FB0CC</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BackgroundBrush"    Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="CardBrush"          Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="PrimaryBrush"       Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush"     Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush"      Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush"         Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"         Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"       Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"       Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"       Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"       Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"       Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"       Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"       Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"       Color="{StaticResource Gray950}"/>

</ResourceDictionary>
